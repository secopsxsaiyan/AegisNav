<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- External storage - read tile/routing files from /sdcard/AegisNav/ -->
    <!-- Android ≤12: READ_EXTERNAL_STORAGE covers all public external storage -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 13+: arbitrary external file access requires MANAGE_EXTERNAL_STORAGE;
         app-scoped storage (Android/data/<package>/) works without any permission.
         For dev, tiles are in internal filesDir which never needs storage permission. -->

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Network (P2P relay) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Battery optimization exemption for continuous BLE + location scanning -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- WiFi scanning -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <!-- Required for WiFi scanning on Android 13+ (API 33); neverForLocation = no location inference -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" android:usesPermissionFlags="neverForLocation" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Required for BLE scanning in foreground service on Android 14+ (API 34) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" android:minSdkVersion="34" />
    <!-- Required for WorkManager foreground service (data sync type) on Android 14+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" android:minSdkVersion="34" />

    <!-- Notifications (Android 13+ requires runtime permission) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Haptic feedback for alerts -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Bluetooth (pre-12 compat) -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <!-- Bluetooth 12+ -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- 3.5 — WorkManager background scan: restart worker on device boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Android 16 (API 36) package visibility: required for TTS engine discovery.
         Ignored on Android 15 and below — no behavioral change on older devices. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:name=".AegisNavApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AegisNav"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <!-- Disable default WorkManager initializer; we use on-demand init via Configuration.Provider -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.AegisNav"
            tools:targetApi="31">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".ScanService"
            android:foregroundServiceType="location|connectedDevice"
            android:exported="false" />

        <!-- WorkManager foreground service: declare dataSync type for TileDownloadWorker -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!--
            3.11 + 3.16 — Permanent background BLE receiver.
            Receives PendingIntent scan results from both the persistent low-power
            scanner (3.11) and the opportunistic scanner (3.16). Android delivers
            these even when the app process is dead.
        -->
        <receiver
            android:name=".scan.BackgroundScanReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.aegisnav.app.BLE_SCAN_RESULT" />
                <action android:name="com.aegisnav.app.OPPORTUNISTIC_SCAN_RESULT" />
            </intent-filter>
        </receiver>

        <!--
            3.15 — Bluetooth state monitoring.
            Receives BluetoothAdapter.ACTION_STATE_CHANGED to pause/resume scanning
            when BT is toggled. Registered in manifest so it fires even when the
            app is not running.
        -->
        <receiver
            android:name=".scan.BluetoothStateMonitor"
            android:exported="false">
            <intent-filter>
                <action android:name="android.bluetooth.adapter.action.STATE_CHANGED" />
            </intent-filter>
        </receiver>


    </application>

</manifest>
